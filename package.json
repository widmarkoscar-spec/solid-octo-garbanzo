{
  "name": "slagbok",
  "private": true,
  "version": "1.0.0",
  "main": "electron.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "se.slagbok.app",
    "productName": "Slagbok",
    "electronVersion": "35.1.2",
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.js"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": {
      "provider": "github",
      "owner": "widmarkoscar-spec",
      "repo": "solid-octo-garbanzo"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "vite": "^6.3.1",
    "wait-on": "^8.0.3"
  }
}
